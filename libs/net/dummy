# shellcheck shell=bash

# net::dummy
# Creates or retrieves a persistent dummy interface with a stable IP address.
#
# Description:
#   This function creates a dummy network interface named 'dummy' with a specified IP address
#   using systemd-networkd for persistence across reboots. It is idempotent: if the interface already
#   exists, it returns the existing IP address without making any changes, regardless of the IP
#   parameter passed. This is useful for providing a stable, routable IP address for services like the
#   Kubernetes API server that need a consistent endpoint.
#
# Usage:
#   net::dummy [cidr]
#
# Parameters:
#   cidr (optional): The IP address with CIDR notation to assign to the interface
#                    (default: 172.30.0.1/24). Can also be set via the 'cidr' environment variable.
#
# Outputs:
#   The IP address (without CIDR notation) of the dummy interface to stdout.
#
# Note:
#   Requires systemd-networkd to be running. Errors if systemd-networkd is not active.
#
function net::dummy() {
  local cidr=${1:-${cidr:-172.30.0.1/24}}

  if ip link show dummy &>/dev/null; then
    ip -4 addr show dummy | grep -oP '(?<=inet\s)\d+(\.\d+){3}'
    return
  fi

  if ! systemctl is-active --quiet systemd-networkd; then
    echo "Error: systemd-networkd is not running" >&2
    return 1
  fi

  cat >/etc/systemd/network/dummy.netdev <<EOT
[NetDev]
Name=dummy
Kind=dummy
EOT

  cat >/etc/systemd/network/dummy.network <<EOT
[Match]
Name=dummy

[Network]
Address=$cidr
EOT

  networkctl reload
  # Wait for interface to come up
  local timeout=30
  while ! ip link show dummy &>/dev/null; do
    ((timeout--)) || {
      echo "Error: timed out waiting for dummy interface" >&2
      return 1
    }
    sleep 1
  done

  echo "${cidr%/*}"
}
