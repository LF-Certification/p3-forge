# shellcheck shell=bash

#include user/get_home
#include system/get_user
#include container/get_runtime

# container::create_system
# Creates and configures a Systemd system container using Docker or nerdctl.
#
# Description:
#   This function sets up a new Systemd system container using a specified image and optional
#   additional arguments. It auto-detects the container runtime, preferring Docker and falling back
#   to nerdctl. It configures a custom systemd slice for resource management and starts the
#   container in privileged mode to ensure full system capabilities. The function also handles SSH
#   key generation for both the current user and sandbox user, copying their public keys into the
#   container to enable SSH access. It mounts necessary system directories (/sys/fs/cgroup and
#   /sys/fs/bpf) and configures the container with host cgroupns. The function waits for the system
#   services within the container to become operational before enabling and starting the SSH
#   service.
#
# Usage:
#   container::create_system [name] [image] [arguments]
#
# Parameters:
#   name (required): The name of the Systemd system container to create.
#   image (required): The container image to use for creating the system container.
#   arguments (optional): Additional run arguments to customize the container setup.
#
# Outputs:
#   None directly. The function prepares the system container for use, including SSH
#   configuration for immediate access.
#
function container::create_system() {
  local name=${1:-${name:?must be set}}
  local image=${2:-${image:?must be set}}
  local arguments=${3:-${arguments:-}}

  local runtime
  runtime=$(container::get_runtime)

  sudo tee "/etc/systemd/system/$name.slice" >/dev/null <<-EOT
[Unit]
Description=Custom Slice for Containers
[Slice]
EOT
  sudo systemctl daemon-reload
  # shellcheck disable=SC2086
  sudo $runtime run --privileged --restart always --name "$name" --hostname "$name" -d -ti \
    -v "/sys/fs/cgroup/$name.slice:/sys/fs/cgroup:rw" -v /sys/fs/bpf:/sys/fs/bpf:rshared \
    --cgroupns host $arguments "$image"

  local user homeDirectory
  for user in $(whoami) $(system::get_user); do
    homeDirectory=$(user::get_home "$user")
    [[ -f "$homeDirectory/.ssh/id_rsa.pub" ]] ||
      sudo -u "$user" ssh-keygen -t rsa -N "" -f "$homeDirectory/.ssh/id_rsa"
    $runtime exec -i "$name" bash -x <<CONTAINER
cat >>$homeDirectory/.ssh/authorized_keys <<KEY
$(<"$homeDirectory/.ssh/id_rsa.pub")
KEY
CONTAINER
  done

  $runtime exec -i "$name" bash -x <<CONTAINER
while ! systemctl is-system-running; do sleep 1; done
systemctl enable --now ssh
CONTAINER
}
