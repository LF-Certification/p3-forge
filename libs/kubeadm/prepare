# shellcheck shell=bash

# kubeadm::prepare
# Prepares a system for Kubernetes with kubeadm.
#
# Description:
#   Handles common setup tasks for a kubeadm-based Kubernetes node: adding the
#   apt repository, installing packages, configuring kernel modules and sysctl
#   settings, and pre-pulling container images.
#
#   Note: This function only supports containerd, not the deprecated Docker CRI.
#
# Usage:
#   kubeadm::prepare
#
# Environment:
#   kubeVersion: Required. Kubernetes version in format "major.minor" or
#                "major.minor.patch" (e.g., "1.35" or "1.35.2").
function kubeadm::prepare() {
  local kubeVersion=${1:-${kubeVersion:?must be specified}}

  # Parse version
  local versions majorMinorVersion version
  IFS=. read -ra versions <<<"$kubeVersion"
  majorMinorVersion="${versions[0]}.${versions[1]}"

  # Add Kubernetes apt repository
  export DEBIAN_FRONTEND=noninteractive
  curl -fsSL "https://pkgs.k8s.io/core:/stable:/v${majorMinorVersion}/deb/Release.key" |
    gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
  echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v${majorMinorVersion}/deb/ /" \
    >/etc/apt/sources.list.d/kubernetes.list
  apt-get update

  # Resolve version: use specified patch version or find latest available
  if [[ -n ${versions[2]:-} ]]; then
    version="${majorMinorVersion}.${versions[2]}"
  else
    version=$(apt-cache madison kubeadm | awk -F'|' '{print $2}' | tr -d ' ' | grep "^${majorMinorVersion}\." | head -1 | cut -d- -f1)
  fi

  # Install packages
  apt-get install -y containerd \
    kubeadm="${version}-*" kubelet="${version}-*" kubectl="${version}-*"
  apt-mark hold kubeadm kubelet kubectl

  # Enable/disable services
  systemctl enable --now containerd
  systemctl disable kubelet

  # Configure shell
  k8s::configure_shell

  # Kernel modules
  mkdir -p /etc/modules-load.d
  cat >/etc/modules-load.d/kubernetes.conf <<EOT
br_netfilter
nf_conntrack
EOT
  modprobe br_netfilter
  modprobe nf_conntrack

  # Sysctl settings
  cat >/etc/sysctl.d/kubernetes.conf <<EOT
net.bridge.bridge-nf-call-iptables = 1
net.ipv6.conf.all.forwarding = 1
net.ipv4.ip_forward = 1
net.netfilter.nf_conntrack_max = 131072
EOT
  sysctl --system

  # CRI tools config
  cat >/etc/crictl.yaml <<EOT
runtime-endpoint: unix:///run/containerd/containerd.sock
image-endpoint: unix:///run/containerd/containerd.sock
EOT

  # Pre-pull images
  kubeadm config images pull
}

# vim: syntax=bash
